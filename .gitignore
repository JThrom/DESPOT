.DS_Store

# Local secrets (Tailscale auth key, etc.)
.tsauth

# ESP-IDF generated outputs
build/
build/**
build_*/
.idf/
managed_components/

# ESP-IDF generated configs/locks
sdkconfig
sdkconfig.old
dependencies.lock

# CMake / compile-database artifacts emitted at project root
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
compile_commands.json

# Host unit-test build tree (test/unit/run.sh -> build/unit)
build/unit/

# Build/log artifacts sometimes emitted at project root
*.bin
*.elf
*.map
flasher_args.json
flash_args
build.log

# Local binaries and scratch outputs
*.out
a.out

# Experimental local assets
main/assets/

# Host unit-test coverage artifacts (build/ is already ignored, but keep these
# in case gcov output lands elsewhere during local runs)
*.gcda
*.gcno
*.gcov
coverage/
